/* Book flip overlap fix — Marcos Garcia Author Site
   Upload this file to the repository root, then link it after style.css.
*/

.enhanced-book-cover {
  position: relative;
  width: 100%;
  max-width: 430px;
  margin: 0 auto;
  padding-bottom: 8px;
}

.book-flip-shell {
  position: relative;
  width: 100%;
  max-width: 430px;
  aspect-ratio: 0.78;
  margin: 0 auto;
  overflow: visible;
}

.book-flip-inner,
.book-face,
.book-back-panel {
  width: 100%;
  height: 100%;
}

.book-face {
  overflow: hidden;
  border-radius: 3px;
}

.book-back-panel {
  padding: clamp(20px, 4vw, 38px) !important;
  justify-content: center;
  overflow: hidden;
}

.book-back-panel h4 {
  margin: 12px 0 !important;
  font-size: clamp(1.45rem, 3vw, 2.35rem) !important;
  line-height: 1.02 !important;
}

.book-back-panel p:not(.book-back-kicker):not(.book-back-author) {
  max-width: 300px !important;
  margin: 0 auto !important;
  font-size: clamp(.78rem, 1.5vw, .95rem) !important;
  line-height: 1.5 !important;
}

.book-back-kicker,
.book-back-author {
  margin: 0 !important;
  font-size: clamp(.56rem, 1.2vw, .68rem) !important;
  line-height: 1.3 !important;
}

.book-back-mark {
  margin: 12px 0 10px !important;
  font-size: 1.5rem !important;
}

.book-flip-button {
  position: relative !important;
  z-index: 20 !important;
  display: block !important;
  width: fit-content;
  max-width: calc(100% - 24px);
  margin: 22px auto 0 !important;
  clear: both;
  isolation: isolate;
}

@media (max-width: 700px) {
  .enhanced-book-cover,
  .book-flip-shell {
    max-width: 340px;
  }

  .book-back-panel {
    padding: 18px !important;
  }

  .book-back-panel h4 {
    font-size: clamp(1.25rem, 7vw, 1.85rem) !important;
  }

  .book-back-panel p:not(.book-back-kicker):not(.book-back-author) {
    font-size: .76rem !important;
    line-height: 1.38 !important;
  }

  .book-back-mark {
    margin: 8px 0 !important;
  }

  .book-flip-button {
    margin-top: 18px !important;
  }
}

@media (max-width: 420px) {
  .book-back-panel h4 {
    margin: 8px 0 !important;
    font-size: 1.2rem !important;
  }

  .book-back-panel p:not(.book-back-kicker):not(.book-back-author) {
    font-size: .7rem !important;
    line-height: 1.32 !important;
  }

  .book-back-mark {
    display: none;
  }
}
